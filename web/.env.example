# The Tool Printer — environment variables
# Copy this file to `.env.local` and fill in the values, or pull from Vercel:
#   vercel env pull .env.local
# Never commit the filled-in file. `.env.local` is gitignored.

# ── Required: Supabase ──────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co (or a custom domain)
NEXT_PUBLIC_SUPABASE_URL=
# Service-role key — server-side reads/writes, bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=
# Anon (public) key. Not required by the current server-rendered reads, but
# set it if you add any client-side Supabase calls.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Required: Admin access ──────────────────────────────────────────────────
# First-run /setup writes a hashed password to the database. ADMIN_PASS is the
# fallback / bootstrap password used until (or unless) you set one via /setup.
ADMIN_PASS=
# JWT signing secret for the admin session cookie. Generate with:
#   openssl rand -hex 32
ADMIN_JWT_SECRET=

# ── AI scoring (Quality Manager) ────────────────────────────────────────────
# You can either set a key here OR configure a provider in /admin/ai-providers
# (which stores the key encrypted in Supabase Vault). One of the two is needed
# for the scoring step to run.
ANTHROPIC_API_KEY=
# Optional override of the scoring model id (defaults are set in code).
AITEA_SCORING_MODEL=

# ── Optional: Apify (YouTube / Twitter / LinkedIn ingest) ───────────────────
# RSS and GitHub work without Apify. The scraped sources need a token + actors.
APIFY_API_TOKEN=
APIFY_YOUTUBE_ACTOR=
APIFY_TWITTER_ACTOR=
APIFY_LINKEDIN_ACTOR=

# ── Optional: Cron protection ───────────────────────────────────────────────
# Set the same value in Vercel's Cron settings so the app can verify cron calls.
CRON_SECRET=

# ── Optional: Email registration (lead magnet on /what-is-this) ─────────────
# /api/register forwards the captured email to an n8n webhook.
N8N_WEBHOOK_URL=
# Sent verbatim as the Authorization header (no "Bearer " prefix).
N8N_AUTH=
